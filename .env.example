# ─── LLM Providers ───────────────────────────────────────────
# At least one provider key is required. You can configure multiple.
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# Default model string for init_chat_model()
# Format: "provider:model" — e.g. "openai:gpt-4o-mini", "anthropic:claude-sonnet-4-20250514", "google-genai:gemini-2.0-flash"
DEFAULT_MODEL=openai:gpt-4o-mini

# ─── Browser Configuration ───────────────────────────────────
# Run browser in headless mode (true/false)
BROWSER_HEADLESS=true

# Max concurrent browser contexts for parallel parsing
MAX_CONCURRENCY=5

# ─── LangSmith Tracing ──────────────────────────────────────
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-browser

# ─── Output ──────────────────────────────────────────────────
# Default directory for saving scraped data
OUTPUT_DIR=output
